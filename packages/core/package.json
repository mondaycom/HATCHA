{
  "name": "@mondaycom/hatcha-core",
  "version": "0.1.1",
  "description": "Challenge generation and cryptographic verification for HATCHA",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "keywords": [
    "captcha",
    "reverse-captcha",
    "ai-agent",
    "verification",
    "hmac",
    "challenge",
    "hatcha"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mondaycom/HATCHA.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/mondaycom/HATCHA#readme",
  "bugs": {
    "url": "https://github.com/mondaycom/HATCHA/issues"
  },
  "license": "MIT",
  "author": "monday.com",
  "publishConfig": {
    "access": "public"
  }
}
