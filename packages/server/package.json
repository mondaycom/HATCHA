{
  "name": "@mondaydotcomorg/hatcha-server",
  "version": "0.1.0",
  "description": "Server middleware for HATCHA — Next.js and Express handlers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "require": "./dist/nextjs.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    }
  },
  "sideEffects": false,
  "keywords": ["captcha", "reverse-captcha", "ai-agent", "server", "nextjs", "express", "middleware", "hatcha"],
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@mondaydotcomorg/hatcha-core": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5",
    "tsup": "^8",
    "typescript": "^5.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mondaycom/HATCHA.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/mondaycom/HATCHA#readme",
  "bugs": {
    "url": "https://github.com/mondaycom/HATCHA/issues"
  },
  "license": "MIT",
  "author": "monday.com",
  "publishConfig": {
    "access": "public"
  }
}
