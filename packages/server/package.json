{
  "name": "@gotcha-captcha/server",
  "version": "0.1.0",
  "description": "Server middleware for GOTCHA — Next.js and Express handlers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "require": "./dist/nextjs.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    }
  },
  "sideEffects": false,
  "keywords": ["captcha", "reverse-captcha", "ai-agent", "server", "nextjs", "express", "middleware", "gotcha"],
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@gotcha-captcha/core": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5",
    "tsup": "^8",
    "typescript": "^5.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mondaycom/gotcha-captcha.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/mondaycom/gotcha-captcha#readme",
  "bugs": {
    "url": "https://github.com/mondaycom/gotcha-captcha/issues"
  },
  "license": "MIT"
}
